          Table[$CellContext`k, {$CellContext`k, $CellContext`y1, \
$CellContext`y2, $CellContext`h}]; $CellContext`xvalues = 
          Table[$CellContext`r 
            Sin[$CellContext`m (Pi/2)], {$CellContext`m, 0, $CellContext`n}]; 
         Line[
           Transpose[{$CellContext`xvalues, $CellContext`yvalues}]]], 
       TagSet[ChartStyle, 
