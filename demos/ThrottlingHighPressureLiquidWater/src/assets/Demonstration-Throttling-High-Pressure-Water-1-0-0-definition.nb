Cell["\<\
Water at high pressure undergoes Joule\[Dash]Thomson expansion when passing \
through a throttling valve. This process is assumed to be adiabatic, so the \
enthalpy change is zero.\
\>", "Text",
 TaggingRules->{},
 CellChangeTimes->{{3.6186852979350586`*^9, 3.6186853354782057`*^9}, {
   3.618685381314828*^9, 3.618685411617561*^9}, {3.6186856178083544`*^9, 
   3.6186857231793814`*^9}, {3.6219668157158213`*^9, 3.621966841515726*^9}, {
   3.623528622835783*^9, 3.62352866297606*^9}, {3.623602088134283*^9, 
   3.623602095331633*^9}, 3.9304319898901*^9},
 CellID->642767726,ExpressionUUID->"2a8b9009-4403-4dc2-a21a-fe4944406f27"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[CapitalDelta]", "\[InvisibleSpace]", "H"}], "=", "0"}], 
   TraditionalForm]], "InlineMath",ExpressionUUID->
  "f7a9b778-e617-4878-8634-648d2e781c70"],
 ", so ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["H", "1"], "=", 
    SubscriptBox["H", "2"]}], TraditionalForm]], "InlineMath",ExpressionUUID->
  "965d7094-af41-4d91-a75f-bb8901225de4"],
 ", where ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["H", "1"], TraditionalForm]], "InlineMath",ExpressionUUID->
  "09f4ddde-0bff-4359-87d1-9cefc664a64b"],
 " is the inlet enthalpy and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["H", "2"], TraditionalForm]], "InlineMath",ExpressionUUID->
  "0af89915-0874-479f-adf2-362c6725104f"],
 " is the exit enthalpy."
}], "Text",
 TaggingRules->{},
 CellChangeTimes->{{3.6186859410848446`*^9, 3.6186860363982964`*^9}, {
  3.6186861663847313`*^9, 3.618686206880047*^9}, {3.61868626217721*^9, 
  3.618686437801255*^9}, {3.6186864963596044`*^9, 3.6186865762111716`*^9}, {
  3.6186866206647143`*^9, 3.618686648592312*^9}, {3.621949145678542*^9, 
  3.6219491456815424`*^9}, {3.621967135157587*^9, 3.6219672158999453`*^9}, {
  3.623528638053301*^9, 3.623528646393228*^9}, {3.6235286792462263`*^9, 
  3.62352874342507*^9}},
 CellID->84987087,ExpressionUUID->"8e2c3252-e6c9-4429-8866-23412b3e3fd8"],

Cell[TextData[{
 "When two phases are present, the saturated vapor enthalpy ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["H", 
    StyleBox["V",
     FontSlant->"Plain"]], TraditionalForm]], "InlineMath",ExpressionUUID->
  "8809a2c6-8576-464b-91cf-8c5da3898bf5"],
 " and the saturated liquid enthalpy ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["H", 
    StyleBox["L",
     FontSlant->"Plain"]], TraditionalForm]], "InlineMath",ExpressionUUID->
  "71485d6b-4fec-40f9-8b5a-be25369b6e80"],
 " are used to determine the fraction of the exit stream that is vapor. For \
the conditions chosen, liquid and vapor exit the throttle at saturation \
conditions, because ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["H", 
     StyleBox["L",
      FontSlant->"Plain"]], "<", 
    SubscriptBox["H", "2"], "<", 
    SuperscriptBox["H", 
     StyleBox["V",
      FontSlant->"Plain"]]}], TraditionalForm]], "InlineMath",ExpressionUUID->
  "a6231c05-a211-4cc5-b1fd-a9eafea65b14"],
 "."
}], "Text",
 TaggingRules->{},
 CellChangeTimes->{{3.6186859410848446`*^9, 3.6186860363982964`*^9}, {
   3.6186861663847313`*^9, 3.618686206880047*^9}, {3.61868626217721*^9, 
   3.618686437801255*^9}, {3.6186864963596044`*^9, 3.6186865494616413`*^9}, {
   3.6219495571190753`*^9, 3.621949613445297*^9}, {3.621966945315143*^9, 
   3.621966990031073*^9}, {3.6219670669613547`*^9, 3.6219671187720995`*^9}, 
   3.622205308417094*^9, {3.6226293546690583`*^9, 3.62262946203146*^9}, {
   3.62352875199765*^9, 3.623528803521502*^9}, {3.623528835756578*^9, 
   3.623528840232547*^9}, 3.623602117274638*^9, {3.7210552712739897`*^9, 
   3.72105529534591*^9}},
 CellID->189155415,ExpressionUUID->"c72fafa7-3e73-4dbc-a892-5d9884006469"],

Cell[TextData[{
 "The steam quality ",
 Cell[BoxData[
  FormBox["q", TraditionalForm]], "InlineMath",ExpressionUUID->
  "b5b0060e-748b-4eea-96df-e72df48a6577"],
 " is calculated by:"
}], "Text",
 TaggingRules->{},
 CellChangeTimes->{{3.6186859410848446`*^9, 3.6186860363982964`*^9}, {
   3.6186861663847313`*^9, 3.618686206880047*^9}, {3.61868626217721*^9, 
   3.618686437801255*^9}, {3.6186864963596044`*^9, 3.6186865494616413`*^9}, {
   3.6219495571190753`*^9, 3.621949613445297*^9}, {3.621966945315143*^9, 
   3.621966990031073*^9}, {3.6219670669613547`*^9, 3.6219671187720995`*^9}, 
   3.622205308417094*^9, {3.6226293546690583`*^9, 3.622629471715339*^9}, {
   3.623528870910013*^9, 3.6235288730476017`*^9}, {3.7197614545011873`*^9, 
   3.7197614545801916`*^9}},
 CellID->5841524,ExpressionUUID->"36044c8a-c486-430f-93bb-e2b273a0ef1a"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["H", "2"], "=", 
    RowBox[{
     RowBox[{"q", " ", 
      SuperscriptBox["H", 
       StyleBox["V",
        FontSlant->"Plain"]]}], "+", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"1", "-", "q"}], ")"}], " ", 
      SuperscriptBox["H", 
       StyleBox["L",
        FontSlant->"Plain"]]}]}]}], TraditionalForm]], "InlineMath",
  ExpressionUUID->"f24752ff-cc21-4d11-ad91-88feb7aedaf9"],
 ","
}], "Text",
 TaggingRules->{},
 CellChangeTimes->{{3.6186859410848446`*^9, 3.6186860363982964`*^9}, {
   3.6186861663847313`*^9, 3.618686206880047*^9}, {3.61868626217721*^9, 
   3.618686437801255*^9}, {3.6186864963596044`*^9, 3.6186865762111716`*^9}, {
   3.6186866206647143`*^9, 3.6186867190613422`*^9}, {3.6219492866216035`*^9, 
   3.6219493086698647`*^9}, {3.6219497529432755`*^9, 3.6219497551094*^9}, {
   3.6219498581392927`*^9, 3.6219498642756433`*^9}, 3.623529010196526*^9, {
   3.623529051202723*^9, 3.623529052105323*^9}, {3.7197614446466236`*^9, 
   3.719761447937812*^9}},
 CellID->663574600,ExpressionUUID->"0f07caea-0fa3-4002-baf7-effeb24d6b01"],

Cell[TextData[{
 "so that ",
 Cell[BoxData[
  FormBox[
   RowBox[{"q", "=", 
    FractionBox[
     RowBox[{
      SubscriptBox["H", "2"], "-", 
      SuperscriptBox["H", 
       StyleBox["L",
        FontSlant->"Plain"]]}], 
     RowBox[{
      SuperscriptBox["H", 
       StyleBox["V",
        FontSlant->"Plain"]], "-", 
      SuperscriptBox["H", 
       StyleBox["L",
        FontSlant->"Plain"]]}]]}], TraditionalForm]], "InlineMath",
  ExpressionUUID->"89323247-6d58-4ac6-af72-8afd99abb591"],
 "."
}], "Text",
 TaggingRules->{},
 CellChangeTimes->{{3.6186859410848446`*^9, 3.6186860363982964`*^9}, {
   3.6186861663847313`*^9, 3.618686206880047*^9}, {3.61868626217721*^9, 
   3.618686437801255*^9}, {3.6186864963596044`*^9, 3.6186865762111716`*^9}, {
   3.6186866206647143`*^9, 3.6186867661280346`*^9}, {3.6186868005420027`*^9, 
   3.6186869246521015`*^9}, {3.6186869863186283`*^9, 
   3.6186870580247297`*^9}, {3.6187760305705547`*^9, 3.618776031921632*^9}, {
   3.621949243618144*^9, 3.6219492608101273`*^9}, {3.6219497915684853`*^9, 
   3.6219498121016593`*^9}, {3.6219498728271327`*^9, 
   3.6219498779124236`*^9}, {3.621967033869071*^9, 3.6219670415017176`*^9}, {
   3.6219672255018454`*^9, 3.6219672280436497`*^9}, 3.623529007822659*^9, {
   3.62352906193159*^9, 3.6235290630991488`*^9}, {3.6781322760091295`*^9, 
   3.6781322770856633`*^9}, {3.7197614510329885`*^9, 
   3.7197614511159935`*^9}, {3.721055310382983*^9, 3.721055310382983*^9}},
 CellID->13964925,ExpressionUUID->"b38a21f1-4aae-4c5e-8937-be5ecd4ae25f"],

Cell[TextData[{
 "When only liquid is present ",
 Cell[BoxData[
  FormBox[
   RowBox[{"q", "=", "0"}], TraditionalForm]], "InlineMath",ExpressionUUID->
  "4f00d969-61f1-4ed6-a11f-9e21e303cbb6"],
 " and ",
