     RowBox[{
      RowBox[{"P1", "=", "20"}], ";", 
      RowBox[{"(*", "MPa", "*)"}], "\[IndentingNewLine]", 
      RowBox[{"H", "=", 
       RowBox[{"HT", "[", "T1", "]"}]}], ";", 
      RowBox[{"HL", "=", 
       RowBox[{"HLP", "[", "P2", "]"}]}], ";", 
      RowBox[{"HV", "=", 
       RowBox[{"HVP", "[", "P2", "]"}]}], ";", 
      RowBox[{"(*", 
       RowBox[{"kJ", "/", "kg"}], "*)"}], "\[IndentingNewLine]", 
      "\[IndentingNewLine]", 
      RowBox[{"q", "=", 
       RowBox[{
        RowBox[{
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{"#", "<", "0"}], ",", "0", ",", "#"}], "]"}], "&"}], "@", 
        FractionBox[
         RowBox[{"H", "-", "HL"}], 
         RowBox[{"HV", "-", "HL"}]]}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"T2", "=", 
