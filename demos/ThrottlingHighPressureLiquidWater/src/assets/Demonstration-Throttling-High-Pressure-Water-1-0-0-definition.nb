Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"vspring", "[", 
    RowBox[{"r_", ",", "y1_", ",", "y2_"}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"n", ",", "h", ",", "yvalues", ",", "xvalues"}], "}"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"n", "=", "150"}], ";", 
      RowBox[{"h", "=", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"y2", "-", "y1"}], ")"}], "/", "n"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"yvalues", "=", 
       RowBox[{"Table", "[", 
        RowBox[{"k", ",", 
         RowBox[{"{", 
          RowBox[{"k", ",", "y1", ",", "y2", ",", "h"}], "}"}]}], "]"}]}], 
      ";", "\[IndentingNewLine]", 
      RowBox[{"xvalues", "=", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"r", "*", 
          RowBox[{"Sin", "[", 
           RowBox[{"m", "*", 
            RowBox[{"\[Pi]", "/", "2"}]}], "]"}]}], ",", 
         RowBox[{"{", 
          RowBox[{"m", ",", "0", ",", "n"}], "}"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"Line", "[", 
       RowBox[{"Transpose", "@", 
        RowBox[{"{", 
         RowBox[{"xvalues", ",", "yvalues"}], "}"}]}], "]"}]}]}], 
    "\[IndentingNewLine]", "]"}]}], ";"}]], "Input",
 TaggingRules->{},
 InitializationCell->True,
 CellID->484898545,ExpressionUUID->"2edc10f9-4717-42c9-9720-e21868af8097"]
