Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Manipulate", "[", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "\[Mu]", ",", "Cc", ",", "Cs", ",", "DCc", ",", "Dmax", ",", "Dmaxprod",
        ",", "ag", ",", "conc", ",", "Dconc"}], "}"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
       RowBox[{"\[Mu]", "[", "d_", "]"}], ":=", 
       RowBox[{"\[Mu]max", "*", 
        FractionBox[
         RowBox[{"Cs", "[", "d", "]"}], 
         RowBox[{"ks", "+", 
          RowBox[{"Cs", "[", "d", "]"}]}]]}]}], ";", "\[IndentingNewLine]", 
      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"Cc", "[", "d_", "]"}], ":=", 
       RowBox[{"Piecewise", "[", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{"0.5", "*", "d", "*", 
             RowBox[{
              RowBox[{"(", 
               RowBox[{"Cs0", "-", 
                RowBox[{"Cs", "[", "d", "]"}]}], ")"}], "/", 
              RowBox[{"\[Mu]", "[", "d", "]"}]}]}], ",", 
            RowBox[{"d", "\[LessEqual]", "Dmax"}]}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"0", ",", 
            RowBox[{"Dmax", "<", "d"}]}], "}"}]}], "}"}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"Cs", "[", "d_", "]"}], ":=", 
       RowBox[{"Piecewise", "[", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{"-", 
             FractionBox[
              RowBox[{"ks", "*", 
               RowBox[{"(", 
                RowBox[{"d", "+", "kd"}], ")"}]}], 
              RowBox[{"d", "+", "kd", "-", "\[Mu]max"}]]}], ",", 
            RowBox[{"d", "\[LessEqual]", "Dmax"}]}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"-", 
             FractionBox[
              RowBox[{"ks", "*", 
               RowBox[{"(", 
                RowBox[{"Dmax", "+", "kd"}], ")"}]}], 
              RowBox[{"Dmax", "+", "kd", "-", "\[Mu]max"}]]}], ",", 
            RowBox[{"Dmax", "<", "d"}]}], "}"}]}], "}"}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"DCc", "[", "d_", "]"}], ":=", 
       RowBox[{"d", "*", 
        RowBox[{"Cc", "[", "d", "]"}]}]}], ";", "\[IndentingNewLine]", 
      "\[IndentingNewLine]", 
      RowBox[{"Dmax", "=", 
       RowBox[{"-", 
        FractionBox[
         RowBox[{
          RowBox[{"Cs0", "*", "kd"}], "+", 
          RowBox[{"kd", "*", "ks"}], "-", 
          RowBox[{"Cs0", "*", "\[Mu]max"}]}], 
         RowBox[{"Cs0", "+", "ks"}]]}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"Dmaxprod", "=", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"Length", "[", 
           RowBox[{"Quiet", "@", 
            RowBox[{
             RowBox[{"FindMaximum", "[", 
              RowBox[{
               RowBox[{"DCc", "[", "d", "]"}], ",", 
               RowBox[{"{", 
                RowBox[{"d", ",", "0.0001", ",", "0", ",", "Dmax"}], "}"}]}], 
              "]"}], "[", 
             RowBox[{"[", "2", "]"}], "]"}]}], "]"}], "\[Equal]", "1"}], ",", 
         
         RowBox[{"d", "/.", 
          RowBox[{"Quiet", "@", 
           RowBox[{
            RowBox[{"FindMaximum", "[", 
             RowBox[{
              RowBox[{"DCc", "[", "d", "]"}], ",", 
              RowBox[{"{", 
               RowBox[{"d", ",", "0.0001", ",", "0", ",", "Dmax"}], "}"}]}], 
             "]"}], "[", 
            RowBox[{"[", "2", "]"}], "]"}]}]}], ",", "0"}], "]"}]}], ";", 
      "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{"ag", "=", 
       RowBox[{"Sequence", "[", 
        RowBox[{
         RowBox[{"Axes", "\[Rule]", "False"}], ",", 
         RowBox[{"LabelStyle", "\[Rule]", "17"}], ",", 
         RowBox[{"ImageSize", "\[Rule]", 
          RowBox[{"{", 
           RowBox[{"600", ",", "370"}], "}"}]}], ",", 
         RowBox[{"AspectRatio", "\[Rule]", "Full"}], ",", 
         RowBox[{"PlotRange", "\[Rule]", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"0", ",", 
              RowBox[{"\[Mu]max", "-", "kd"}]}], "}"}], ",", 
            RowBox[{"{", 
             RowBox[{"0", ",", "All"}], "}"}]}], "}"}]}], ",", 
         RowBox[{"PlotRangePadding", "\[Rule]", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"None", ",", "None"}], "}"}], ",", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"Scaled", "@", "0.045"}], ",", 
              RowBox[{"Scaled", "@", "0.26"}]}], "}"}]}], "}"}]}], ",", 
         RowBox[{"ImagePadding", "\[Rule]", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"50", ",", "85"}], "}"}], ",", 
            RowBox[{"{", 
             RowBox[{"60", ",", "5"}], "}"}]}], "}"}]}], ",", 
         RowBox[{"PlotRangeClipping", "\[Rule]", "True"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{"conc", "=", 
       RowBox[{"Graphics", "[", 
        RowBox[{
         RowBox[{"{", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"Thick", ",", "Blue", ",", 
             RowBox[{"Line", "[", 
              RowBox[{"Table", "[", 
               RowBox[{
                RowBox[{"{", 
                 RowBox[{"d", ",", 
                  RowBox[{"Cs", "[", "d", "]"}]}], "}"}], ",", 
                RowBox[{"{", 
                 RowBox[{"d", ",", "0.00001", ",", "Dmax", ",", "0.0001"}], 
                 "}"}]}], "]"}], "]"}], ",", 
             RowBox[{"Line", "[", 
              RowBox[{"{", 
               RowBox[{
                RowBox[{"{", 
                 RowBox[{"Dmax", ",", 
                  RowBox[{"Cs", "[", "Dmax", "]"}]}], "}"}], ",", 
                RowBox[{"{", 
                 RowBox[{
                  RowBox[{"\[Mu]max", "-", "kd"}], ",", 
                  RowBox[{"Cs", "[", "Dmax", "]"}]}], "}"}]}], "}"}], "]"}], 
             ",", "Dashed", ",", 
             RowBox[{"Line", "[", 
              RowBox[{"Table", "[", 
               RowBox[{
                RowBox[{"{", 
                 RowBox[{"d", ",", 
                  RowBox[{"Cc", "[", "d", "]"}]}], "}"}], ",", 
                RowBox[{"{", 
                 RowBox[{"d", ",", "0.00001", ",", "Dmax", ",", "0.001"}], 
                 "}"}]}], "]"}], "]"}], ",", 
             RowBox[{"Line", "[", 
              RowBox[{"{", 
               RowBox[{
                RowBox[{"{", 
                 RowBox[{"Dmax", ",", "0"}], "}"}], ",", 
                RowBox[{"{", 
                 RowBox[{
                  RowBox[{"\[Mu]max", "-", "kd"}], ",", "0"}], "}"}]}], "}"}],
               "]"}]}], "}"}], ",", "\[IndentingNewLine]", 
           RowBox[{"Text", "[", 
            RowBox[{
             RowBox[{"Framed", "[", 
              RowBox[{
               RowBox[{"Style", "[", 
                RowBox[{
                 RowBox[{"Subscript", "[", 
                  RowBox[{
                   RowBox[{"Style", "[", 
                    RowBox[{"\"\<C\>\"", ",", "Italic"}], "]"}], ",", 
                   "\"\<cell\>\""}], "]"}], ",", "18", ",", "Blue"}], "]"}], 
               ",", 
               RowBox[{"Background", "\[Rule]", "White"}], ",", 
               RowBox[{"FrameMargins", "\[Rule]", "Tiny"}], ",", 
               RowBox[{"FrameStyle", "\[Rule]", "None"}]}], "]"}], ",", 
             RowBox[{"If", "[", 
              RowBox[{
               RowBox[{"Dmax", ">", "0"}], ",", 
               RowBox[{"{", 
                RowBox[{
                 RowBox[{"0.5", "*", "Dmax"}], ",", 
                 RowBox[{"Cc", "[", 
                  RowBox[{"0.5", "*", "Dmax"}], "]"}]}], "}"}], ",", 
               RowBox[{"{", 
                RowBox[{
                 RowBox[{"0.5", "*", 
                  RowBox[{"(", 
                   RowBox[{"\[Mu]max", "-", "kd"}], ")"}]}], ",", 
                 RowBox[{"Cc", "[", 
                  RowBox[{"0.5", "*", 
                   RowBox[{"(", 
                    RowBox[{"\[Mu]max", "-", "kd"}], ")"}]}], "]"}]}], 
                "}"}]}], "]"}]}], "]"}], ",", "\[IndentingNewLine]", 
           RowBox[{"Text", "[", 
            RowBox[{
             RowBox[{"Framed", "[", 
              RowBox[{
               RowBox[{"Style", "[", 
                RowBox[{
                 RowBox[{"Subscript", "[", 
                  RowBox[{
                   RowBox[{"Style", "[", 
                    RowBox[{"\"\<C\>\"", ",", "Italic"}], "]"}], ",", 
                   "\"\<substrate\>\""}], "]"}], ",", "18", ",", "Blue"}], 
                "]"}], ",", 
               RowBox[{"Background", "\[Rule]", "White"}], ",", 
               RowBox[{"FrameMargins", "\[Rule]", "Tiny"}], ",", 
               RowBox[{"FrameStyle", "\[Rule]", "None"}]}], "]"}], ",", 
             RowBox[{"{", 
              RowBox[{
               RowBox[{"0.85", "*", 
                RowBox[{"(", 
                 RowBox[{"\[Mu]max", "-", "kd"}], ")"}]}], ",", 
               RowBox[{"Cs", "[", 
                RowBox[{"0.85", "*", 
                 RowBox[{"(", 
                  RowBox[{"\[Mu]max", "-", "kd"}], ")"}]}], "]"}]}], "}"}]}], 
            "]"}], ",", "\[IndentingNewLine]", 
           RowBox[{"Text", "[", 
            RowBox[{
             RowBox[{"Framed", "@", 
              RowBox[{"Style", "[", 
               RowBox[{
                RowBox[{"Column", "[", 
                 RowBox[{
                  RowBox[{"{", "\[IndentingNewLine]", 
                   RowBox[{
                    RowBox[{"Row", "@", 
                    RowBox[{"{", 
                    RowBox[{
                    "\"\<dilution rate for maximum production = \>\"", ",", 
                    RowBox[{"NumberForm", "[", 
                    RowBox[{
                    RowBox[{"If", "[", 
                    RowBox[{
                    RowBox[{"Dmaxprod", "<", "0.00001"}], ",", "0", ",", 
                    "Dmaxprod"}], "]"}], ",", 
                    RowBox[{"{", 
                    RowBox[{"4", ",", "2"}], "}"}]}], "]"}], ",", 
                    RowBox[{"Superscript", "[", 
                    RowBox[{"\"\< h\>\"", ",", 
                    RowBox[{"-", "1"}]}], "]"}]}], "}"}]}], ",", 
                    "\[IndentingNewLine]", 
                    RowBox[{"Row", "@", 
                    RowBox[{"{", 
                    RowBox[{"\"\<washout dilution rate = \>\"", ",", 
                    RowBox[{"NumberForm", "[", 
                    RowBox[{
                    RowBox[{"If", "[", 
                    RowBox[{
                    RowBox[{"Dmax", "<", "0.0001"}], ",", "0", ",", "Dmax"}], 
                    "]"}], ",", 
                    RowBox[{"{", 
                    RowBox[{"5", ",", "2"}], "}"}]}], "]"}], ",", 
                    RowBox[{"Superscript", "[", 
                    RowBox[{"\"\< h\>\"", ",", 
                    RowBox[{"-", "1"}]}], "]"}]}], "}"}]}]}], 
                   "\[IndentingNewLine]", "}"}], ",", "Center"}], "]"}], ",", 
                "18"}], "]"}]}], ",", 
             RowBox[{"Scaled", "@", 
              RowBox[{"{", 
               RowBox[{"0.41", ",", "0.89"}], "}"}]}]}], "]"}]}], 
          "\[IndentingNewLine]", "}"}], ",", "\[IndentingNewLine]", 
         RowBox[{"Frame", "\[Rule]", 
          RowBox[{"{", 
           RowBox[{"True", ",", "True", ",", "True", ",", "False"}], "}"}]}], 
         ",", "\[IndentingNewLine]", 
         RowBox[{"FrameStyle", "\[Rule]", 
          RowBox[{"{", 
           RowBox[{"Black", ",", "Blue", ",", "Black", ",", "Black"}], 
           "}"}]}], ",", "\[IndentingNewLine]", 
         RowBox[{"FrameLabel", "\[Rule]", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"Row", "@", 
             RowBox[{"{", 
              RowBox[{"\"\<dilution rate (\>\"", ",", 
               RowBox[{"Superscript", "[", 
                RowBox[{"\"\<h\>\"", ",", 
                 RowBox[{"-", "1"}]}], "]"}], ",", "\"\<)\>\""}], "}"}]}], 
            ",", "\"\<concentration (g/L)\>\"", ",", "None", ",", "None"}], 
           "}"}]}], ",", "\[IndentingNewLine]", 
         RowBox[{"Evaluate", "@", "ag"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{"Dconc", "=", 
       RowBox[{"Graphics", "[", 
        RowBox[{
         RowBox[{"{", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"Thick", ",", 
             RowBox[{"RGBColor", "[", 
              RowBox[{"0", ",", "0.6", ",", "0"}], "]"}], ",", 
             RowBox[{"Line", "[", 
              RowBox[{"Table", "[", 
               RowBox[{
                RowBox[{"{", 
                 RowBox[{"d", ",", 
                  RowBox[{"DCc", "[", "d", "]"}]}], "}"}], ",", 
                RowBox[{"{", 
                 RowBox[{"d", ",", "0.00001", ",", 
                  RowBox[{"1.1", "*", "Dmax"}], ",", "0.001"}], "}"}]}], 
               "]"}], "]"}], ",", 
             RowBox[{"Line", "[", 
              RowBox[{"{", 
               RowBox[{
                RowBox[{"{", 
                 RowBox[{"Dmax", ",", "0"}], "}"}], ",", 
                RowBox[{"{", 
                 RowBox[{
                  RowBox[{"\[Mu]max", "-", "kd"}], ",", "0"}], "}"}]}], "}"}],
               "]"}]}], "}"}], ",", "\[IndentingNewLine]", 
           RowBox[{"Text", "[", 
            RowBox[{
             RowBox[{"Framed", "[", 
              RowBox[{
               RowBox[{"Style", "[", 
                RowBox[{
                 RowBox[{"Row", "@", 
                  RowBox[{"{", 
                   RowBox[{
                    RowBox[{"Style", "[", 
                    RowBox[{"\"\<D\>\"", ",", "Italic"}], "]"}], ",", 
                    RowBox[{"Style", "[", 
                    RowBox[{"\"\< \[Times] \>\"", ",", "10"}], "]"}], ",", 
                    RowBox[{"Subscript", "[", 
                    RowBox[{
                    RowBox[{"Style", "[", 
                    RowBox[{"\"\<C\>\"", ",", "Italic"}], "]"}], ",", 
                    "\"\<cell\>\""}], "]"}]}], "}"}]}], ",", "18", ",", 
                 RowBox[{"RGBColor", "[", 
                  RowBox[{"0", ",", "0.6", ",", "0"}], "]"}]}], "]"}], ",", 
               RowBox[{"Background", "\[Rule]", "White"}], ",", 
               "\[IndentingNewLine]", 
