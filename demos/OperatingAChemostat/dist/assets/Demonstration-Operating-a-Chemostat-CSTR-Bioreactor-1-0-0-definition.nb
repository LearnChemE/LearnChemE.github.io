$CellContext`ag$, $CellContext`conc$, $CellContext`Dconc$}, \
$CellContext`\[Mu]$[
           Pattern[$CellContext`d$, 
            
            Blank[]]] := $CellContext`\[Mu]max$$ \
($CellContext`Cs$[$CellContext`d$]/($CellContext`ks$$ + \
$CellContext`Cs$[$CellContext`d$])); $CellContext`Cc$[
           Pattern[$CellContext`d$, 
