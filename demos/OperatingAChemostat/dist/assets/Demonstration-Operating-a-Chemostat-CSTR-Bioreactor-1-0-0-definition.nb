$CellContext`kd$$)/($CellContext`d$ + $CellContext`kd$$ - \
$CellContext`\[Mu]max$$))), $CellContext`d$ <= $CellContext`Dmax$}, \
{-($CellContext`ks$$ (($CellContext`Dmax$ + \
$CellContext`kd$$)/($CellContext`Dmax$ + $CellContext`kd$$ - $CellContext`\
\[Mu]max$$))), $CellContext`Dmax$ < $CellContext`d$}}]; $CellContext`DCc$[
           Pattern[$CellContext`d$, 
            
            Blank[]]] := $CellContext`d$ $CellContext`Cc$[$CellContext`d$]; \
$CellContext`Dmax$ = -(($CellContext`Cs0$$ $CellContext`kd$$ + \
$CellContext`kd$$ $CellContext`ks$$ - $CellContext`Cs0$$ \
$CellContext`\[Mu]max$$)/($CellContext`Cs0$$ + $CellContext`ks$$)); \
$CellContext`Dmaxprod$ = If[Length[
