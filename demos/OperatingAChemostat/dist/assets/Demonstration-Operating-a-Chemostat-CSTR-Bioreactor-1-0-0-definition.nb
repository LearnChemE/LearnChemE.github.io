                   Superscript[" h", -1]}], 
                 Row[{"washout dilution rate = ", 
                   NumberForm[
                    If[$CellContext`Dmax$ < 0.0001, 0, $CellContext`Dmax$], {
                    5, 2}], 
                   Superscript[" h", -1]}]}, Center], 18]], 
             Scaled[{0.41, 0.89}]]}, Frame -> {True, True, True, False}, 
           FrameStyle -> {Black, Blue, Black, Black}, FrameLabel -> {
             Row[{"dilution rate (", 
               Superscript["h", -1], ")"}], "concentration (g/L)", None, 
